# GCP Configuration
GOOGLE_CLOUD_PROJECT="your-gcp-project-id"
GOOGLE_CLOUD_LOCATION="us-central1"

# IAP Configuration. Format: /projects/PROJECT_NUMBER/global/backendServices/SERVICE_ID
IAP_AUDIENCE="/projects/123456789/global/backendServices/1234567890123456789"

# Development Mode (set to 'dev' for local testing without IAP)
ENVIRONMENT="dev"
DEV_USER_EMAIL="dev@example.com"
