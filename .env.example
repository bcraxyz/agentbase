# GCP Configuration
GOOGLE_CLOUD_PROJECT="your-gcp-project-id"
GOOGLE_CLOUD_LOCATION="us-central1"

# IAP Configuration (for production)
# Get this from: Cloud Console > Security > Identity-Aware Proxy > Your Service
# Format: /projects/PROJECT_NUMBER/global/backendServices/SERVICE_ID
IAP_AUDIENCE="/projects/123456789/global/backendServices/1234567890123456789"

# Development Mode (set to 'development' for local testing without IAP)
ENVIRONMENT="development"
DEV_USER_EMAIL="developer@example.com"
