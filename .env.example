# GCP Configuration
GOOGLE_CLOUD_PROJECT="your-gcp-project-id"
GOOGLE_CLOUD_LOCATION="us-central1"

# IAP Configuration (for production)
# Get this using: gcloud run services describe SERVICE_NAME --region=REGION --format="value(metadata.annotations.'run.googleapis.com/ingress-status')"
# Or from Cloud Run service details: Audience claim = /projects/PROJECT_NUMBER/apps/PROJECT_ID
# Format for Cloud Run with IAP: /projects/PROJECT_NUMBER/apps/PROJECT_ID
IAP_AUDIENCE="/projects/123456789/apps/your-project-id"

# Development Mode (set to 'dev' for local testing without IAP)
ENVIRONMENT="dev"
DEV_USER_EMAIL="dev@example.com"
